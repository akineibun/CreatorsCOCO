{
  "name": "creatorscoco",
  "version": "1.2.5",
  "description": "CG Creator Studio desktop shell",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "build:app": "npm run build && npm run backend:build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "backend:test": "python -m unittest discover -s python-backend/tests -p \"test_*.py\"",
    "backend:install-native": "powershell -ExecutionPolicy Bypass -File ./python-backend/install-native-backends.ps1",
    "backend:setup-sam3-native": "powershell -ExecutionPolicy Bypass -File ./python-backend/setup-native-sam3.ps1",
    "backend:build": "powershell -ExecutionPolicy Bypass -File ./python-backend/build-backend.ps1",
    "smoke:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/portable-smoke.ps1",
    "dist:dir": "npm run build:app && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist:win": "npm run build:app && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "dist:nsis": "npm run build:app && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akineibun/CreatorsCOCO.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/akineibun/CreatorsCOCO/issues"
  },
  "homepage": "https://github.com/akineibun/CreatorsCOCO#readme",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.1.0",
    "jszip": "^3.10.1",
    "konva": "^10.2.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.creatorscoco.app",
    "productName": "CreatorsCOCO",
    "icon": "assets/app-icon.ico",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python-backend/dist",
        "to": "python-backend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "python-backend/dist/**"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
